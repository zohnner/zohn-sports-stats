/*
  # Security headers — applied to every response by Cloudflare Pages
  # CSP covers all external origins the app actually fetches/loads.
  # Note: 'unsafe-inline' is required for script-src because the current codebase
  # uses inline onclick/onkeydown handlers and dynamically-set innerHTML event attrs.
  # Future hardening: migrate inline handlers to JS event listeners and remove 'unsafe-inline'.

  # connect-src includes api.balldontlie.io for local dev (BDL_PROXY_URL='').
  # Once the Worker is deployed, replace https://api.balldontlie.io with your Worker URL
  # (e.g. https://sportsstrata-proxy.your-subdomain.workers.dev) and remove the BDL origin.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://a.espncdn.com https://www.mlbstatic.com https://img.mlbstatic.com; connect-src 'self' https://api.balldontlie.io https://site.api.espn.com https://stats.nba.com https://statsapi.mlb.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  X-XSS-Protection: 0
